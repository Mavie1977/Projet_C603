{
  "name": "pnae-rca/v10-enterprise-stable",
  "type": "project",
  "description": "PNAE-RCA V10 Enterprise Stable - Laravel e-administration platform",
  "require": {
    "php": "^8.4",
    "barryvdh/laravel-dompdf": "^3.1",
    "endroid/qr-code": "^6.1",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.27",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^12.0"
  },
  "autoload": {"psr-4": {"App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/"}},
  "autoload-dev": {"psr-4": {"Tests\\": "tests/"}},
  "scripts": {
    "post-autoload-dump": ["Illuminate\\Foundation\\ComposerScripts::postAutoloadDump", "@php artisan package:discover --ansi"],
    "post-root-package-install": ["@php -r \"file_exists('.env') || copy('.env.example', '.env');\""],
    "post-create-project-cmd": ["@php artisan key:generate --ansi"]
  },
  "config": {"optimize-autoloader": true, "preferred-install": "dist", "sort-packages": true, "allow-plugins": {"pestphp/pest-plugin": true, "php-http/discovery": true}},
  "minimum-stability": "stable",
  "prefer-stable": true
}
